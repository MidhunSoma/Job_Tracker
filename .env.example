# Master configurations
LOG_FILE_PATH=logs/agent.log
FUZZY_MATCH_THRESHOLD=85.0

# Database Settings
DB__URL=sqlite:///data/tracker.db

# LLM Configuration
# Swappable providers: openai, gemini, anthropic
LLM__PROVIDER=openai
LLM__MODEL=gpt-4o-mini
LLM__OPENAI_API_KEY=your_openai_api_key_here
LLM__GEMINI_API_KEY=your_gemini_api_key_here
LLM__ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail API Configuration
GMAIL__CLIENT_ID=your_google_oauth_client_id_here
GMAIL__CLIENT_SECRET=your_google_oauth_client_secret_here
GMAIL__REDIRECT_URI=http://localhost:8000/api/auth/callback
GMAIL__TOKEN_PATH=data/token.json
GMAIL__HISTORY_DAYS=30

# Excel Export Configuration
EXPORT__EXCEL_PATH=exports/job_applications.xlsx

# Scheduler Configuration
SCHEDULER__INTERVAL_MINUTES=60
